# Sift — environment configuration
# Copy to .env and adjust values as needed.

# Postgres connection string
SIFT_MCP_POSTGRES_DSN=postgresql://sift:sift@localhost:5432/sift

# Root data directory (default: .sift-mcp/)
# SIFT_MCP_DATA_DIR=.sift-mcp

# Envelope JSONB storage mode: full | minimal_for_large | none
# SIFT_MCP_ENVELOPE_JSONB_MODE=full

# Canonical bytes compression: zstd | gzip | none
# SIFT_MCP_ENVELOPE_CANONICAL_ENCODING=zstd

# Max JSON part size before byte-backed offload (bytes)
# SIFT_MCP_MAX_JSON_PART_PARSE_BYTES=50000000

# Cursor TTL in minutes
# SIFT_MCP_CURSOR_TTL_MINUTES=60

# Where clause canonicalization: raw_string | canonical_ast
# SIFT_MCP_WHERE_CANONICALIZATION_MODE=raw_string

# Integration test Postgres DSN (defaults to docker-compose test DB)
# SIFT_MCP_TEST_POSTGRES_DSN=postgresql://sift:sift@localhost:5432/sift_test
