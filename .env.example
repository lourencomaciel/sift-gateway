# Sift — environment configuration
# Copy to .env and adjust values as needed.

# Root data directory (default: .sift-gateway/)
# SIFT_GATEWAY_DATA_DIR=.sift-gateway

# Envelope JSONB storage mode: full | minimal_for_large | none
# SIFT_GATEWAY_ENVELOPE_JSONB_MODE=full

# Canonical bytes compression: gzip | none
# SIFT_GATEWAY_ENVELOPE_CANONICAL_ENCODING=gzip

# Max JSON part size before byte-backed offload (bytes)
# SIFT_GATEWAY_MAX_JSON_PART_PARSE_BYTES=50000000

# Cursor TTL in minutes
# SIFT_GATEWAY_CURSOR_TTL_MINUTES=60
