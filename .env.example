# SidePouch — environment configuration
# Copy to .env and adjust values as needed.

# Postgres connection string
SIDEPOUCH_MCP_POSTGRES_DSN=postgresql://sidepouch:sidepouch@localhost:5432/sidepouch

# Root data directory (default: .sidepouch-mcp/)
# SIDEPOUCH_MCP_DATA_DIR=.sidepouch-mcp

# Envelope JSONB storage mode: full | minimal_for_large | none
# SIDEPOUCH_MCP_ENVELOPE_JSONB_MODE=full

# Canonical bytes compression: zstd | gzip | none
# SIDEPOUCH_MCP_ENVELOPE_CANONICAL_ENCODING=zstd

# Max JSON part size before byte-backed offload (bytes)
# SIDEPOUCH_MCP_MAX_JSON_PART_PARSE_BYTES=50000000

# Cursor TTL in minutes
# SIDEPOUCH_MCP_CURSOR_TTL_MINUTES=60

# Where clause canonicalization: raw_string | canonical_ast
# SIDEPOUCH_MCP_WHERE_CANONICALIZATION_MODE=raw_string

# Integration test Postgres DSN (defaults to docker-compose test DB)
# SIDEPOUCH_MCP_TEST_POSTGRES_DSN=postgresql://sidepouch:sidepouch@localhost:5432/sidepouch_test
