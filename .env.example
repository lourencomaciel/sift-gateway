# MCP Artifact Gateway — environment configuration
# Copy to .env and adjust values as needed.

# Postgres connection string
MCP_GATEWAY_POSTGRES_DSN=postgresql://mcp_gateway:mcp_gateway@localhost:5432/mcp_gateway

# Root data directory (default: .mcp_gateway/)
# MCP_GATEWAY_DATA_DIR=.mcp_gateway

# Envelope JSONB storage mode: full | minimal_for_large | none
# MCP_GATEWAY_ENVELOPE_JSONB_MODE=full

# Canonical bytes compression: zstd | gzip | none
# MCP_GATEWAY_ENVELOPE_CANONICAL_ENCODING=zstd

# Max JSON part size before byte-backed offload (bytes)
# MCP_GATEWAY_MAX_JSON_PART_PARSE_BYTES=50000000

# Cursor TTL in minutes
# MCP_GATEWAY_CURSOR_TTL_MINUTES=60

# Where clause canonicalization: raw_string | canonical_ast
# MCP_GATEWAY_WHERE_CANONICALIZATION_MODE=raw_string
